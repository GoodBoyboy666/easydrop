# Full EASYDROP_ environment variable template.
# Copy this file to .env and edit values for your deployment.
# Replace all change_me placeholders before production use.

# Server
EASYDROP_SERVER_MODE=production
EASYDROP_SERVER_ADDR=:8080
# Comma-separated values for array fields.
EASYDROP_SERVER_TRUSTED_PROXIES=
EASYDROP_SERVER_REMOTE_IP_HEADERS=X-Forwarded-For,X-Real-IP
EASYDROP_SERVER_READ_TIMEOUT=10s
EASYDROP_SERVER_WRITE_TIMEOUT=15s
EASYDROP_SERVER_SHUTDOWN_TIMEOUT=5s

# Auth cookie
EASYDROP_AUTH_COOKIE_NAME=easydrop_access_token
EASYDROP_AUTH_COOKIE_PATH=/
EASYDROP_AUTH_COOKIE_DOMAIN=
EASYDROP_AUTH_COOKIE_SAME_SITE=lax

# Database
EASYDROP_DB_DRIVER=sqlite
EASYDROP_DB_SQLITE_PATH=data/easydrop.db
EASYDROP_DB_HOST=127.0.0.1
EASYDROP_DB_PORT=3306
EASYDROP_DB_USERNAME=change_me
EASYDROP_DB_PASSWORD=change_me
EASYDROP_DB_DATABASE_NAME=easydrop
EASYDROP_DB_SSL_MODE=disable
EASYDROP_DB_CHARSET=utf8mb4
EASYDROP_DB_PARSE_TIME=true
EASYDROP_DB_LOC=Local
EASYDROP_DB_TIME_ZONE=Asia/Shanghai
EASYDROP_DB_MAX_OPEN_CONNS=20
EASYDROP_DB_MAX_IDLE_CONNS=10
EASYDROP_DB_CONN_MAX_LIFETIME=1h
EASYDROP_DB_CONN_MAX_IDLE_TIME=10m

# Redis
EASYDROP_REDIS_ADDR=
EASYDROP_REDIS_USERNAME=
EASYDROP_REDIS_PASSWORD=change_me
EASYDROP_REDIS_DB=0
EASYDROP_REDIS_DIAL_TIMEOUT=5s
EASYDROP_REDIS_READ_TIMEOUT=3s
EASYDROP_REDIS_WRITE_TIMEOUT=3s
EASYDROP_REDIS_POOL_SIZE=10
EASYDROP_REDIS_MIN_IDLE_CONNS=2
EASYDROP_REDIS_MAX_RETRIES=3

# Rate limit
EASYDROP_RATE_LIMIT_ENABLED=false
EASYDROP_RATE_LIMIT_KEY_PREFIX=ratelimit
# Dynamic map key pattern:
# EASYDROP_RATE_LIMIT_RULES_<RULE_NAME>_(INTERVAL|LIMIT)
EASYDROP_RATE_LIMIT_RULES_AUTH_WRITE_INTERVAL=2s
EASYDROP_RATE_LIMIT_RULES_AUTH_WRITE_LIMIT=1
EASYDROP_RATE_LIMIT_RULES_INIT_WRITE_INTERVAL=10s
EASYDROP_RATE_LIMIT_RULES_INIT_WRITE_LIMIT=1
EASYDROP_RATE_LIMIT_RULES_PROFILE_WRITE_INTERVAL=1m
EASYDROP_RATE_LIMIT_RULES_PROFILE_WRITE_LIMIT=10
EASYDROP_RATE_LIMIT_RULES_USER_SECURITY_WRITE_INTERVAL=30s
EASYDROP_RATE_LIMIT_RULES_USER_SECURITY_WRITE_LIMIT=1
EASYDROP_RATE_LIMIT_RULES_COMMENT_WRITE_INTERVAL=30s
EASYDROP_RATE_LIMIT_RULES_COMMENT_WRITE_LIMIT=5
EASYDROP_RATE_LIMIT_RULES_ATTACHMENT_WRITE_INTERVAL=1m
EASYDROP_RATE_LIMIT_RULES_ATTACHMENT_WRITE_LIMIT=20

# Email
EASYDROP_EMAIL_ENABLE=false
EASYDROP_EMAIL_HOST=smtp.example.com
EASYDROP_EMAIL_PORT=587
EASYDROP_EMAIL_USERNAME=change_me
EASYDROP_EMAIL_PASSWORD=change_me
EASYDROP_EMAIL_FROM_EMAIL=noreply@example.com
EASYDROP_EMAIL_TLS_MODE=starttls
EASYDROP_EMAIL_CONNECT_TIMEOUT=10s
EASYDROP_EMAIL_SEND_TIMEOUT=10s

# JWT
EASYDROP_JWT_PRIVATE_KEY_PATH=data/jwt/private.pem
EASYDROP_JWT_PUBLIC_KEY_PATH=data/jwt/public.pem
EASYDROP_JWT_ISSUER=easydrop
EASYDROP_JWT_EXPIRE=24h

# Captcha
EASYDROP_CAPTCHA_ENABLED=false
EASYDROP_CAPTCHA_PROVIDER=turnstile
EASYDROP_CAPTCHA_TIMEOUT=5s
EASYDROP_CAPTCHA_TURNSTILE_SITE_KEY=change_me
EASYDROP_CAPTCHA_TURNSTILE_SECRET_KEY=change_me
EASYDROP_CAPTCHA_TURNSTILE_VERIFY_URL=
EASYDROP_CAPTCHA_RECAPTCHA_SITE_KEY=change_me
EASYDROP_CAPTCHA_RECAPTCHA_SECRET_KEY=change_me
EASYDROP_CAPTCHA_RECAPTCHA_VERIFY_URL=
EASYDROP_CAPTCHA_HCAPTCHA_SITE_KEY=change_me
EASYDROP_CAPTCHA_HCAPTCHA_SECRET_KEY=change_me
EASYDROP_CAPTCHA_HCAPTCHA_VERIFY_URL=
EASYDROP_CAPTCHA_GEETEST_V4_SITE_KEY=change_me
EASYDROP_CAPTCHA_GEETEST_V4_SECRET_KEY=change_me
EASYDROP_CAPTCHA_GEETEST_V4_VERIFY_URL=

# Avatar
EASYDROP_AVATAR_GRAVATAR_BASE_URL=https://www.gravatar.com/avatar/

# Storage
EASYDROP_STORAGE_BACKEND=local
EASYDROP_STORAGE_LOCAL_BASE_PATH=data/uploads
EASYDROP_STORAGE_LOCAL_URL_PREFIX=
EASYDROP_STORAGE_S3_BUCKET=
EASYDROP_STORAGE_S3_REGION=
EASYDROP_STORAGE_S3_ACCESS_KEY=change_me
EASYDROP_STORAGE_S3_SECRET_KEY=change_me
EASYDROP_STORAGE_S3_ENDPOINT=
EASYDROP_STORAGE_S3_USE_PATH_STYLE=false
EASYDROP_STORAGE_S3_PUBLIC_BASE_URL=
EASYDROP_STORAGE_S3_PRESIGN_EXPIRE=15m

# Token
EASYDROP_TOKEN_KEY_PREFIX=token
